    {
      "name": "📦 Product Information",
      "item": [
        {
          "name": "Product 1: Yamaha YZF-R1",
          "item": [
            {
              "name": "1. Init Purchase Request - Product 10",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"Response has product details\", function () {",
                      "    var jsonData = pm.response.json();",
                      "    pm.expect(jsonData.productId).to.equal(10);",
                      "    pm.expect(jsonData.price).to.equal(15000);",
                      "    pm.expect(jsonData.depositAmount).to.equal(1500);",
                      "    pm.expect(jsonData.platformFee).to.equal(750);",
                      "    pm.expect(jsonData.inspectionFee).to.equal(450);",
                      "});",
                      "",
                      "pm.test(\"Total amount calculated correctly\", function () {",
                      "    var jsonData = pm.response.json();",
                      "    var total = jsonData.price + jsonData.depositAmount + jsonData.platformFee + jsonData.inspectionFee;",
                      "    pm.expect(jsonData.totalAmount).to.equal(total);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/products/10/purchase-request/init",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "products",
                    "10",
                    "purchase-request",
                    "init"
                  ]
                }
              }
            },
            {
              "name": "2. Review Purchase Request - Product 10",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"Response validation success\", function () {",
                      "    var jsonData = pm.response.json();",
                      "    pm.expect(jsonData.validated).to.be.true;",
                      "    pm.expect(jsonData.productId).to.equal(10);",
                      "});"
                    ],
                    "type": "text/javascript"
