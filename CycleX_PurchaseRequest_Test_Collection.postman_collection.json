            {
              "name": "3. Create Purchase Request - Product 10",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 201 (Created)\", function () {",
                      "    pm.response.to.have.status(201);",
                      "});",
                      "",
                      "pm.test(\"Purchase request created with correct data\", function () {",
                      "    var jsonData = pm.response.json();",
                      "    pm.expect(jsonData.productId).to.equal(10);",
                      "    pm.expect(jsonData.buyerId).to.equal(101);",
                      "    pm.expect(jsonData.status).to.equal('PENDING_SELLER_CONFIRM');",
                      "    pm.expect(jsonData.depositAmount).to.equal(1500);",
                      "});",
                      "",
                      "pm.test(\"Response has request ID\", function () {",
                      "    var jsonData = pm.response.json();",
                      "    pm.expect(jsonData.requestId).to.exist;",
                      "    console.log('✅ Purchase Request Created - ID: ' + jsonData.requestId);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
